# ============================================
# CONFIGURACIÓN DJANGO
# ============================================

# Clave secreta - cambiar en producción
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=tu-clave-secreta-aqui

# Modo debug - True para desarrollo, False para producción
DEBUG=False

# Hosts permitidos - separados por comas
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# BASE DE DATOS
# ============================================

# Para SQLite (desarrollo)
DATABASE_URL=sqlite:///db.sqlite3

# Para PostgreSQL (producción en Render)
# DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# CORS (Cross-Origin Resource Sharing)
# ============================================

# Orígenes permitidos - separados por comas
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# INSTRUCCIONES
# ============================================
# 1. Copiar este archivo a .env
# 2. Modificar los valores según tu entorno
# 3. NUNCA commitear el archivo .env
# 4. En Render, configurar estas variables en el dashboard
